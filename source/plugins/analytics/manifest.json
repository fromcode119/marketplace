{
  "slug": "analytics",
  "name": "Site Analytics",
  "version": "1.0.0",
  "description": "Native event tracking and Google Analytics / Plausible integration.",
  "author": "Fromcode Core",
  "homepage": "https://fromcode.com",
  "category": "productivity",
  "iconUrl": "https://raw.githubusercontent.com/lucide-react/lucide/main/icons/bar-chart-3.svg",
  "capabilities": [
    "database:write",
    "hooks"
  ],
  "admin": {
    "group": "Intelligence",
    "icon": "Activity",
    "menu": [
      {
        "label": "Intelligence",
        "path": "/plugins/analytics",
        "icon": "TrendingUp",
        "priority": 1
      },
      {
        "label": "Events Log",
        "path": "/plugins/analytics/events",
        "icon": "List",
        "priority": 2
      }
    ],
    "slots": {
      "admin.plugin.analytics.content": "admin.plugin.analytics.dashboard"
    },
    "management": {
      "settings": [
        {
          "name": "ga_measurement_id",
          "label": "GA4 Measurement ID",
          "type": "text",
          "placeholder": "G-XXXXXXXXXX"
        },
        {
          "name": "track_user_roles",
          "label": "Track Admin Sessions",
          "type": "boolean",
          "defaultValue": false
        }
      ]
    }
  }
}
