{
  "slug": "cms",
  "name": "Content Management System",
  "version": "1.3.2",
  "main": "index.js",
  "description": "Enterprise-grade CMS - Advanced Security Update.",
  "author": "Fromcode Core",
  "homepage": "https://fromcode.com",
  "iconUrl": "https://raw.githubusercontent.com/lucide-react/lucide/main/icons/layout-template.svg",
  "screenshots": [
    "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?q=80&w=800&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=800&auto=format&fit=crop"
  ],
  "changelog": [
    "Integrated Role-Based Access Control (RBAC)",
    "Added support for multi-language content fields",
    "Optimized query performance for large datasets",
    "Enhanced image optimization pipeline"
  ],
  "capabilities": [
    "api",
    "content",
    "i18n",
    "hooks",
    "email",
    "storage",
    "security",
    "monitoring",
    "networking",
    "backups"
  ],
  "permissions": [],
  "admin": {
    "group": "Content",
    "icon": "LayoutTemplate",
    "slots": [
      {
        "slot": "admin.dashboard.widgets",
        "component": "CMSDashboard",
        "priority": 5
      },
      {
        "slot": "admin.plugin.cms.content",
        "component": "CMSDashboard",
        "priority": 10
      }
    ],
    "menu": [
      {
        "label": "Blog Posts",
        "path": "/posts",
        "icon": "FileText",
        "group": "Content"
      },
      {
        "label": "Pages",
        "path": "/pages",
        "icon": "Layers",
        "group": "Content"
      },
      {
        "label": "Categories",
        "path": "/categories",
        "icon": "Tag",
        "group": "Content"
      }
    ],
    "management": {
      "settings": [
        {
          "name": "enable_drafts",
          "label": "Enable Drafts by Default",
          "type": "boolean",
          "defaultValue": true
        },
        {
          "name": "auto_generate_excerpts",
          "label": "Auto-generate Excerpts",
          "type": "boolean",
          "defaultValue": true
        }
      ]
    }
  },
  "ui": {
    "entry": "index.js"
  }
}
