# Marketplace Hub Configuration
NODE_ENV=production
MARKETPLACE_PORT=4000

# Database Configuration
DATABASE_URL=sqlite:./data/marketplace.db

# Admin Configuration
ADMIN_USER=admin@example.invalid
ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
NEXT_PUBLIC_ADMIN_AI_ENABLED=false

# Framework source
FRAMEWORK_REPO_URL=https://github.com/fromcode119/framework.git
FRAMEWORK_REF=main

# Optional GitHub access token for runtime plugin/theme clones
GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>
